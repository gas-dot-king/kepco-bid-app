# ─────────────────────────────────────────────────────
# 한전 빅데이터 API 키
#   발급처: https://bigdata.kepco.co.kr
# ─────────────────────────────────────────────────────
KEPCO_API_KEY=

# ─────────────────────────────────────────────────────
# 조달청 나라장터 - 입찰공고정보서비스 인증키
#   발급처: https://www.data.go.kr → "나라장터 입찰공고정보서비스" 검색 → 활용신청
# ─────────────────────────────────────────────────────
G2B_BID_API_KEY=

# ─────────────────────────────────────────────────────
# 조달청 나라장터 - 낙찰정보서비스 인증키
#   발급처: https://www.data.go.kr → "나라장터 낙찰정보서비스" 검색 → 활용신청
#   (입찰공고 서비스와 동일한 키를 발급받은 경우 위와 동일하게 입력)
# ─────────────────────────────────────────────────────
G2B_RESULT_API_KEY=

# ─────────────────────────────────────────────────────
# 서버 포트 (기본값 3000)
# ─────────────────────────────────────────────────────
PORT=3000
